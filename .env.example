# OAuth configuration for ansible-mcp server authentication
ANSIBLE_MCP_CLIENT_ID=your_oauth_client_id_here
ANSIBLE_MCP_CLIENT_SECRET=your_oauth_client_secret_here
ANSIBLE_MCP_ISSUER_URL=https://your-auth-provider.com/
ANSIBLE_MCP_AUDIENCE=your-mcp-audience
ANSIBLE_MCP_SERVER_URL=https://your-mcp-server.com/mcp

# Language Model Configuration
# Choose one of the following:

# OpenAI Configuration
OPENAI_API_KEY=sk-your-actual-openai-key-here

# Anthropic Configuration  
ANTHROPIC_API_KEY=sk-ant-your-actual-anthropic-key-here

# AWS Configuration (if using Parameter Store)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# AWS Account IDs (for multi-account demos)
TARGET_AWS_ACCOUNT=your_target_account_id_here
AGENT_AWS_ACCOUNT=your_agent_account_id_here

# LangSmith Tracing Configuration (optional)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=your_project_name_here